# Auto detect text files and normalize line endings to LF in repo
* text=auto

# Force LF for specific file types
*.java text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.properties text eol=lf

# Binary files
*.jar binary
*.war binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
