<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controller.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RoleListServlet</servlet-name>
        <servlet-class>controller.RoleListServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EditRoleServlet</servlet-name>
        <servlet-class>controller.EditRoleServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EditRolePermissionsServlet</servlet-name>
        <servlet-class>controller.EditRolePermissionsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RoleListServlet</servlet-name>
        <url-pattern>/role-list</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EditRoleServlet</servlet-name>
        <url-pattern>/edit-role</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EditRolePermissionsServlet</servlet-name>
        <url-pattern>/edit-role-permissions</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>views/login.jsp</welcome-file>
    </welcome-file-list>
</web-app>
