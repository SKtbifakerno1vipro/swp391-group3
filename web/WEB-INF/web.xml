<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>UserController</servlet-name>
        <servlet-class>controller.user.UserController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CustomerDetailController</servlet-name>
        <servlet-class>controller.customer.CustomerDetailController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CreateCustomerController</servlet-name>
        <servlet-class>controller.customer.CreateCustomerController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EditCustomerController</servlet-name>
        <servlet-class>controller.customer.EditCustomerController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CustomerListController</servlet-name>
        <servlet-class>controller.customer.CustomerListController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CreateProviderController</servlet-name>
        <servlet-class>controller.provider.CreateProviderController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProviderDetailController</servlet-name>
        <servlet-class>controller.provider.ProviderDetailController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProviderListController</servlet-name>
        <servlet-class>controller.provider.ProviderListController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controller.auth.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>controller.auth.LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RoleListServlet</servlet-name>
        <servlet-class>controller.role.RoleListServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AddRoleController</servlet-name>
        <servlet-class>controller.role.AddRoleController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RoleController</servlet-name>
        <servlet-class>controller.role.RoleController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EditRoleServlet</servlet-name>
        <servlet-class>controller.role.EditRoleServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EditRolePermissionsServlet</servlet-name>
        <servlet-class>controller.role.EditRolePermissionsServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>UserController</servlet-name>
        <url-pattern>/user</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CustomerDetailController</servlet-name>
        <url-pattern>/CustomerDetail</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CreateCustomerController</servlet-name>
        <url-pattern>/CreateCustomer</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EditCustomerController</servlet-name>
        <url-pattern>/EditCustomer</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CustomerListController</servlet-name>
        <url-pattern>/customer-list</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CreateProviderController</servlet-name>
        <url-pattern>/CreateProvider</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProviderDetailController</servlet-name>
        <url-pattern>/ProviderDetail</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProviderListController</servlet-name>
        <url-pattern>/provider-list</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RoleListServlet</servlet-name>
        <url-pattern>/role-list</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AddRoleController</servlet-name>
        <url-pattern>/add-role</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RoleController</servlet-name>
        <url-pattern>/role</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EditRoleServlet</servlet-name>
        <url-pattern>/edit-role</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EditRolePermissionsServlet</servlet-name>
        <url-pattern>/edit-role-permissions</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>views/auth/login.jsp</welcome-file>
    </welcome-file-list>
</web-app>
