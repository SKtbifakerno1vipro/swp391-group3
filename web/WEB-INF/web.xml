<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>CustomerDetailController</servlet-name>
        <servlet-class>controllers.CustomerDetailController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CreateCustomerController</servlet-name>
        <servlet-class>controllers.CreateCustomerController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>EditCustomerController</servlet-name>
        <servlet-class>controllers.EditCustomerController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerDetailController</servlet-name>
        <url-pattern>/CustomerDetail</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CreateCustomerController</servlet-name>
        <url-pattern>/CreateCustomer</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>EditCustomerController</servlet-name>
        <url-pattern>/EditCustomer</url-pattern>
    </servlet-mapping>
</web-app>
